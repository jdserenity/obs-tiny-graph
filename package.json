{
  "name": "obsidian-tiny-graph",
  "version": "0.1.0",
  "description": "Embed compact interactive graphs inside notes using a code block. Tiny, custom Canvas2D, YAML config, no heavy libs.",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["obsidian", "obsidian-plugin", "graph", "local-graph", "canvas"],
  "license": "MIT",
  "dependencies": {
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "esbuild": "0.25.5",
    "obsidian": "latest",
    "typescript": "^5.8.3",
    "vitest": "^3.1.0"
  }
}
